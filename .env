DATABASE_URL=file:./db/custom.db

# Cloudflare Tunnel / domaine public :
# Laisse cette variable commentée pour que le navigateur utilise automatiquement
# le même domaine que la page, ex. https://play.lavignere.eu/socket.io
# Le tunnel ou le reverse proxy redirige ensuite /socket.io vers le serveur de jeu local sur 50007.
# NEXT_PUBLIC_GAME_SERVER_URL=https://play.lavignere.eu

# Ancien mode box/NAT direct, à éviter avec Cloudflare Tunnel :
# NEXT_PUBLIC_GAME_SERVER_PORT=50007
